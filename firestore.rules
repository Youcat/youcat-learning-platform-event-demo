rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function validQuestion(questionId) {
      return questionId in ["3", "14", "25", "34", "59", "68", "83", "126", "127", "140"];
    }

    function validRoom(roomId) {
      return roomId.matches("^[A-Z0-9-]{3,16}$");
    }

    match /rooms/{roomId}/questions/{questionId}/reflections/{answerId} {
      allow read: if signedIn();

      allow create: if signedIn()
        && validRoom(roomId)
        && validQuestion(questionId)
        && answerId == request.auth.uid
        && request.resource.data.keys().hasOnly([
          "authorUid", "name", "age", "text", "voters", "createdAt"
        ])
        && request.resource.data.authorUid == request.auth.uid
        && request.resource.data.name is string
        && request.resource.data.name.size() >= 1
        && request.resource.data.name.size() <= 60
        && request.resource.data.age is int
        && request.resource.data.age >= 18
        && request.resource.data.age <= 120
        && request.resource.data.text is string
        && request.resource.data.text.size() >= 1
        && request.resource.data.text.size() <= 1200
        && request.resource.data.voters is list
        && request.resource.data.voters.size() == 0
        && request.resource.data.createdAt == request.time;

      allow update: if signedIn()
        && resource.data.authorUid != request.auth.uid
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(["voters"])
        && resource.data.voters is list
        && request.resource.data.voters is list
        && request.resource.data.voters.hasAll(resource.data.voters)
        && !resource.data.voters.hasAny([request.auth.uid])
        && request.resource.data.voters.hasAny([request.auth.uid])
        && request.resource.data.voters.size() == resource.data.voters.size() + 1
        && request.resource.data.voters.size() <= 80;

      allow delete: if false;
    }
  }
}
