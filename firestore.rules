rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function validQuestion(questionId) {
      return questionId in ["3", "14", "25", "34", "59", "68", "83", "126", "127", "140"];
    }

    function validRoom(roomId) {
      return roomId in [
        "Assis-Sao-Jose", "Assis-Sao-Francisco", "Assis-Santa-Clara", "Assis-Santo-Antonio",
        "Assis-Sao-Joao-Paulo", "Assis-Santa-Teresa-de-Calcuta", "Assis-Sao-Pedro", "Assis-Sao-Paulo",
        "Assis-Santa-Rita", "Assis-Sao-Bento", "Assis-Santa-Teresinha", "Assis-Sao-Joao-Bosco",
        "Assis-Santa-Faustina", "Assis-Santo-Agostinho", "Assis-Santa-Monica", "Assis-Sao-Padre-Pio",
        "Assis-Santa-Catarina", "Assis-Sao-Domingos", "Assis-Santa-Gianna", "Assis-Sao-Maximiliano-Kolbe"
      ];
    }

    match /{path=**}/reflections/{answerId} {
      allow read: if signedIn();
    }

    match /rooms/{roomId}/questions/{questionId}/reflections/{answerId} {
      allow read: if signedIn();

      allow create: if signedIn()
        && validRoom(roomId)
        && validQuestion(questionId)
        && answerId == request.auth.uid
        && request.resource.data.keys().hasOnly([
          "authorUid", "name", "age", "text", "voters", "roomCode", "questionNumber", "createdAt"
        ])
        && request.resource.data.authorUid == request.auth.uid
        && request.resource.data.name is string
        && request.resource.data.name.size() >= 1
        && request.resource.data.name.size() <= 60
        && (!request.resource.data.keys().hasAny(["age"])
          || (request.resource.data.age is int
            && request.resource.data.age >= 18
            && request.resource.data.age <= 120))
        && request.resource.data.text is string
        && request.resource.data.text.size() >= 1
        && request.resource.data.text.size() <= 300
        && request.resource.data.voters is list
        && request.resource.data.voters.size() == 0
        && request.resource.data.roomCode is string
        && request.resource.data.roomCode == roomId
        && request.resource.data.questionNumber == questionId
        && request.resource.data.createdAt == request.time;

      allow update: if signedIn()
        && resource.data.authorUid != request.auth.uid
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(["voters"])
        && resource.data.voters is list
        && request.resource.data.voters is list
        && request.resource.data.voters.hasAll(resource.data.voters)
        && !resource.data.voters.hasAny([request.auth.uid])
        && request.resource.data.voters.hasAny([request.auth.uid])
        && request.resource.data.voters.size() == resource.data.voters.size() + 1
        && request.resource.data.voters.size() <= 200;

      allow delete: if false;
    }

    match /leaderboardParticipants/{participantId} {
      allow read: if signedIn();
      allow create, update: if signedIn()
        && participantId == request.auth.uid
        && request.resource.data.keys().hasOnly([
          "uid", "displayName", "currentGroup", "personalXp", "updatedAt"
        ])
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.displayName is string
        && request.resource.data.displayName.size() >= 1
        && request.resource.data.displayName.size() <= 40
        && validRoom(request.resource.data.currentGroup)
        && request.resource.data.personalXp is int
        && request.resource.data.personalXp >= 0
        && request.resource.data.personalXp <= 20000
        && request.resource.data.updatedAt == request.time;
      allow delete: if false;
    }

    match /{path=**}/members/{participantId} {
      allow read: if signedIn();
    }

    match /leaderboardGroups/{roomId}/members/{participantId} {
      allow create, update: if signedIn()
        && validRoom(roomId)
        && participantId == request.auth.uid
        && request.resource.data.keys().hasOnly([
          "uid", "groupCode", "displayName", "personalXp", "groupXp", "questionXp", "active", "reflectionStatus", "boardCompleted", "updatedAt"
        ])
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.groupCode == roomId
        && request.resource.data.displayName is string
        && request.resource.data.displayName.size() >= 1
        && request.resource.data.displayName.size() <= 40
        && request.resource.data.personalXp is int
        && request.resource.data.personalXp >= 0
        && request.resource.data.personalXp <= 20000
        && request.resource.data.groupXp is int
        && request.resource.data.groupXp >= 0
        && request.resource.data.groupXp <= 20000
        && request.resource.data.questionXp is map
        && request.resource.data.active is bool
        && (!request.resource.data.keys().hasAny(["reflectionStatus"])
          || request.resource.data.reflectionStatus is map)
        && (!request.resource.data.keys().hasAny(["boardCompleted"])
          || request.resource.data.boardCompleted is map)
        && request.resource.data.updatedAt == request.time;
      allow delete: if false;
    }

    match /leaderboardGroupSummaries/{roomId} {
      allow read: if signedIn();
      allow create, update: if signedIn()
        && validRoom(roomId)
        && request.resource.data.keys().hasOnly([
          "groupCode", "totalXp", "participants", "members", "reflectionResolved", "averageXp", "updatedAt"
        ])
        && request.resource.data.groupCode == roomId
        && request.resource.data.totalXp is number
        && request.resource.data.totalXp >= 0
        && request.resource.data.totalXp <= 4000000
        && request.resource.data.participants is int
        && request.resource.data.participants >= 0
        && request.resource.data.participants <= 200
        && (!request.resource.data.keys().hasAny(["members"])
          || (request.resource.data.members is int
            && request.resource.data.members >= 0
            && request.resource.data.members <= 200))
        && (!request.resource.data.keys().hasAny(["reflectionResolved"])
          || request.resource.data.reflectionResolved is map)
        && request.resource.data.averageXp is number
        && request.resource.data.averageXp >= 0
        && request.resource.data.averageXp <= 20000
        && request.resource.data.updatedAt == request.time;
      allow delete: if false;
    }

    match /leaderboardQuestionSummaries/{summaryId} {
      allow read: if signedIn();
      allow create, update: if signedIn()
        && validRoom(request.resource.data.groupCode)
        && validQuestion(request.resource.data.questionNumber)
        && summaryId == request.resource.data.groupCode + "__" + request.resource.data.questionNumber
        && request.resource.data.keys().hasOnly([
          "groupCode", "questionNumber", "totalXp", "updatedAt"
        ])
        && request.resource.data.totalXp is number
        && request.resource.data.totalXp >= 0
        && request.resource.data.totalXp <= 4000000
        && request.resource.data.updatedAt == request.time;
      allow delete: if false;
    }

    match /missionParticipants/{participantId} {
      allow read, create, update: if signedIn() && participantId == request.auth.uid;
      allow delete: if false;
    }

    match /missionGroups/{roomId} {
      allow read, create, update: if signedIn() && validRoom(roomId);
      allow delete: if false;
    }

    match /missionEvent/{documentId} {
      allow read, create, update: if signedIn() && documentId == "assis-2026-07-26";
      allow delete: if false;
    }

    match /heartAllocations/{allocationId} {
      allow read: if signedIn();
      allow create, update: if signedIn()
        && request.resource.data.keys().hasOnly(["uid", "questionNumber", "reflectionIds", "updatedAt"])
        && request.resource.data.uid == request.auth.uid
        && validQuestion(request.resource.data.questionNumber)
        && request.resource.data.reflectionIds is list
        && request.resource.data.reflectionIds.size() >= 1
        && request.resource.data.reflectionIds.size() <= 3
        && allocationId == request.auth.uid + "__" + request.resource.data.questionNumber
        && request.resource.data.updatedAt == request.time;
      allow delete: if false;
    }

    match /heartRewards/{rewardId} {
      allow read: if signedIn() && resource.data.authorUid == request.auth.uid;
      allow create: if signedIn()
        && request.resource.data.keys().hasOnly([
          "authorUid", "voterUid", "reflectionId", "questionNumber", "xp", "createdAt"
        ])
        && request.resource.data.voterUid == request.auth.uid
        && validQuestion(request.resource.data.questionNumber)
        && rewardId == request.resource.data.authorUid + "__" + request.resource.data.questionNumber + "__" + request.auth.uid
        && request.resource.data.xp == 5
        && request.resource.data.createdAt == request.time;
      allow update, delete: if false;
    }
  }
}
